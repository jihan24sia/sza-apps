<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF6F2"
    tools:context=".Home.pertemuan_4.FourthActivity">

    <!-- CARD -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardView"
        android:layout_width="260dp"
        android:layout_height="260dp"
        android:backgroundTint="#FFE4E1"
        app:cardCornerRadius="25dp"
        app:cardElevation="6dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/btnBack"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="80dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="20dp">

            <!-- BUTTON 1 -->
            <Button
                android:id="@+id/btn1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Tombol 1"
                android:textColor="#6D4C41"
                android:backgroundTint="#FFD1DC"
                android:padding="10dp"
                app:cornerRadius="20dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <!-- SNACKBAR -->
            <Button
                android:id="@+id/btnShowSnackbar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Tampilkan Snackbar"
                android:textColor="#6D4C41"
                android:backgroundTint="#FFECB3"
                android:padding="10dp"
                app:cornerRadius="20dp"
                app:layout_constraintTop_toBottomOf="@id/btn1"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="15dp"/>

            <!-- ALERT DIALOG -->
            <Button
                android:id="@+id/btnShowAlertDialog"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Tampilkan AlertDialog"
                android:textColor="#6D4C41"
                android:backgroundTint="#C8E6C9"
                android:padding="10dp"
                app:cornerRadius="20dp"
                app:layout_constraintTop_toBottomOf="@id/btnShowSnackbar"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="15dp"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- BUTTON BACK -->
    <Button
        android:id="@+id/btnBack"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:text="Kembali"
        android:textColor="#FFFFFF"
        android:backgroundTint="#F48FB1"
        android:padding="12dp"
        app:cornerRadius="25dp"
        app:layout_constraintTop_toBottomOf="@id/cardView"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="40dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>